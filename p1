<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unplugged Coding: ภารกิจผึ้งน้อย</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@400;600&display=swap');

        body {
            font-family: 'Sarabun', sans-serif;
            background-color: #fdf5e6;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h1 {
            color: #d35400;
            margin-bottom: 5px;
            text-shadow: 1px 1px 2px #f39c12;
        }

        .subtitle {
            margin-bottom: 15px;
            font-size: 16px;
            color: #555;
            text-align: center;
        }

        .level-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
            background: #fff;
            padding: 10px 20px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            border: 2px solid #f39c12;
        }

        .level-header h2 {
            margin: 0;
            color: #2980b9;
        }

        select {
            padding: 5px 10px;
            font-family: 'Sarabun', sans-serif;
            font-size: 16px;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        /* Command Palette */
        .commands-palette {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            justify-content: center;
            border: 2px dashed #f39c12;
            padding: 15px;
            border-radius: 10px;
            background-color: #fff;
        }

        .cmd-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: #fff;
            border: 2px solid #ddd;
            border-radius: 8px;
            padding: 10px;
            cursor: pointer;
            transition: 0.2s;
            width: 70px;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
        }

        .cmd-btn:hover {
            border-color: #f39c12;
            background-color: #fff9e6;
            transform: scale(1.05);
        }

        .cmd-icon { font-size: 30px; margin-bottom: 5px; }
        .cmd-text { font-size: 12px; font-weight: 600; text-align: center; }

        /* Game Grid */
        .game-board {
            display: grid;
            grid-template-columns: repeat(8, 60px);
            grid-template-rows: repeat(6, 60px);
            gap: 2px;
            background-color: #555;
            border: 4px solid #555;
            margin-bottom: 20px;
        }

        .cell {
            background-color: #e0f7fa;
            width: 60px;
            height: 60px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 35px;
            position: relative;
        }

        .cell.grass { background-color: #c8e6c9; }
        .cell.sky { background-color: #e1f5fe; }
        .cell.path { background-color: #d7ccc8; }

        .bee {
            position: absolute;
            font-size: 40px;
            transition: all 0.3s ease;
            z-index: 10;
        }

        /* Command Slots Container */
        .slots-container {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            gap: 2px;
            background-color: #000;
            border: 2px solid #000;
            width: 100%;
            max-width: 600px;
            margin-bottom: 20px;
        }

        .slot {
            background-color: #fff;
            height: 50px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 24px;
            position: relative;
        }

        .slot-number {
            position: absolute;
            top: 2px;
            left: 4px;
            font-size: 10px;
            color: #888;
        }

        /* Controls */
        .controls {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
        }

        .btn {
            padding: 10px 20px;
            font-size: 16px;
            font-family: 'Sarabun', sans-serif;
            font-weight: bold;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.2);
            transition: 0.2s;
        }

        .btn-run { background-color: #2ecc71; color: white; }
        .btn-run:hover { background-color: #27ae60; }
        
        .btn-clear { background-color: #e74c3c; color: white; }
        .btn-clear:hover { background-color: #c0392b; }

        .btn-next { background-color: #3498db; color: white; display: none; }
        .btn-next:hover { background-color: #2980b9; }

        #message {
            font-size: 18px;
            font-weight: bold;
            color: #d35400;
            height: 24px;
            text-align: center;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <h1>Unplugged Coding</h1>
    <div class="subtitle">ให้เด็กๆ เติมบัตรคำสั่งลงในช่องด้านล่างตามลำดับ<br>เพื่อพาผึ้งไปเก็บน้ำหวานและสร้างรังผึ้งให้ครบตามเป้าหมาย (มีทั้งหมด 20 ด่าน)</div>

    <!-- ส่วนเลือกด่าน -->
    <div class="level-header">
        <h2 id="level-display">ด่านที่ 1/20</h2>
        <select id="level-select" onchange="changeLevel(this.value)">
            <!-- JS จะสร้างตัวเลือกด่านที่นี่ -->
        </select>
    </div>

    <!-- ปุ่มคำสั่ง -->
    <div class="commands-palette">
        <div class="cmd-btn" onclick="addCommand('RIGHT', '➡️')">
            <span class="cmd-icon">➡️</span><span class="cmd-text">เดินขวา</span>
        </div>
        <div class="cmd-btn" onclick="addCommand('LEFT', '⬅️')">
            <span class="cmd-icon">⬅️</span><span class="cmd-text">เดินซ้าย</span>
        </div>
        <div class="cmd-btn" onclick="addCommand('UP', '⬆️')">
            <span class="cmd-icon">⬆️</span><span class="cmd-text">เดินขึ้น</span>
        </div>
        <div class="cmd-btn" onclick="addCommand('DOWN', '⬇️')">
            <span class="cmd-icon">⬇️</span><span class="cmd-text">เดินลง</span>
        </div>
        <div class="cmd-btn" onclick="addCommand('FLOWER', '🌻')">
            <span class="cmd-icon">🌻</span><span class="cmd-text">เก็บน้ำหวาน</span>
        </div>
        <div class="cmd-btn" onclick="addCommand('HONEY', '🍯')">
            <span class="cmd-icon">🍯</span><span class="cmd-text">เก็บน้ำผึ้ง</span>
        </div>
    </div>

    <div class="game-board" id="board"></div>
    <div class="slots-container" id="slots"></div>

    <div class="controls">
        <button class="btn btn-clear" onclick="resetLevel()">ลบคำสั่ง/เริ่มด่านใหม่</button>
        <button class="btn btn-run" onclick="runCommands()">▶️ เริ่มทำงาน</button>
        <button class="btn btn-next" id="btn-next" onclick="nextLevel()">ด่านต่อไป ⏭️</button>
    </div>
    
    <div id="message"></div>

    <script>
        const COLS = 8;
        const ROWS = 6;
        const MAX_COMMANDS = 24;
        
        let beePos = { r: 0, c: 0 };
        let commandsList = [];
        let currentMapData = [];
        let currentLevelIndex = 0;
        let isRunning = false;

        // ข้อมูล 20 ด่านการเรียนรู้ (F = ดอกไม้, H = รังผึ้ง)
        const levels = [
            // --- ระดับพื้นฐาน (ด่าน 1-5) ---
            { start: { r: 3, c: 1 }, targetScore: 1, map: [
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','F','','','',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            { start: { r: 1, c: 4 }, targetScore: 1, map: [
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','','H','','',''],
                ['','','','','','','','']
            ]},
            { start: { r: 1, c: 2 }, targetScore: 1, map: [
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','','','F','',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            { start: { r: 0, c: 0 }, targetScore: 2, map: [
                ['','','','','','','',''],
                ['','','F','','','','',''],
                ['','','','','','','',''],
                ['','','H','','','','',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            { start: { r: 5, c: 0 }, targetScore: 2, map: [
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','F','','','','',''],
                ['','','','','H','','',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            
            // --- ระดับกลาง (ด่าน 6-10) ---
            { start: { r: 5, c: 7 }, targetScore: 2, map: [
                ['','','','','','','',''],
                ['','','','H','','','',''],
                ['','','','','','','',''],
                ['','','','','','F','',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            { start: { r: 2, c: 1 }, targetScore: 3, map: [
                ['','','','','','','',''],
                ['','','','','F','','',''],
                ['','','F','','','','',''],
                ['','','','','','','F',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            { start: { r: 4, c: 2 }, targetScore: 2, map: [
                ['','H','','','','','',''],
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','','','','H',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            { start: { r: 2, c: 3 }, targetScore: 4, map: [
                ['','','','','','','',''],
                ['','','F','','H','','',''],
                ['','','','','','','',''],
                ['','','H','','F','','',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            { start: { r: 0, c: 7 }, targetScore: 5, map: [
                ['F','','','','','','',''],
                ['','','','F','','','',''],
                ['','','','','','','',''],
                ['','H','','','F','','',''],
                ['','','','','','','H',''],
                ['','','','','','','','']
            ]},

            // --- ระดับสูง (ด่าน 11-20 ท้าทายกระบวนการคิด) ---
            { // ด่าน 11: การเดินเป็นรูปตัว U
                start: { r: 1, c: 1 }, targetScore: 3, map: [
                ['','','','','','','',''],
                ['','','','','','F','',''],
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','F','','','','H','',''],
                ['','','','','','','','']
            ]},
            { // ด่าน 12: การเดินสลับฟันปลาขนาดเล็ก
                start: { r: 0, c: 0 }, targetScore: 3, map: [
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','F','','','H','',''],
                ['','','','','','','',''],
                ['','','','','F','','',''],
                ['','','','','','','','']
            ]},
            { // ด่าน 13: เดินทะแยงขั้นบันได
                start: { r: 5, c: 0 }, targetScore: 4, map: [
                ['','','','','','','',''],
                ['','','','F','','','',''],
                ['','','','','','','',''],
                ['','','','','H','','',''],
                ['','','','','','','',''],
                ['','','F','','','H','','']
            ]},
            { // ด่าน 14: สำรวจขอบทวีป
                start: { r: 5, c: 7 }, targetScore: 4, map: [
                ['','H','','','','','',''],
                ['','','','','','','',''],
                ['','','','','H','','',''],
                ['','','','','','','',''],
                ['','','','F','','','',''],
                ['','','','','','F','','']
            ]},
            { // ด่าน 15: ระยะทางไกล
                start: { r: 0, c: 7 }, targetScore: 4, map: [
                ['','','F','','','','',''],
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','H','','','','F',''],
                ['','','','','','','',''],
                ['','','','','','','H','']
            ]},
            { // ด่าน 16: รอบวงกลมใหญ่
                start: { r: 1, c: 1 }, targetScore: 4, map: [
                ['','','','','','','',''],
                ['','','','','','','F',''],
                ['','','','','','','',''],
                ['','H','','','','','',''],
                ['','F','','','','','H',''],
                ['','','','','','','','']
            ]},
            { // ด่าน 17: ซิกแซกระดับสุดยอด
                start: { r: 0, c: 0 }, targetScore: 5, map: [
                ['','','','F','','','',''],
                ['','','','','','','',''],
                ['','','','H','','','F',''],
                ['','','','','','','',''],
                ['','','','','','','H',''],
                ['','','','','','','','F']
            ]},
            { // ด่าน 18: กากบาทแห่งทางเดิน
                start: { r: 0, c: 4 }, targetScore: 4, map: [
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','F','','F','','',''],
                ['','H','','','','H','',''],
                ['','','','','','','',''],
                ['','','','','','','','']
            ]},
            { // ด่าน 19: เดินเข้าสู่จุดศูนย์กลาง
                start: { r: 5, c: 7 }, targetScore: 4, map: [
                ['','','','','','','',''],
                ['','','','','','','','F'],
                ['','','H','','','','',''],
                ['','','','','','','',''],
                ['','','F','','','H','',''],
                ['','','','','','','','']
            ]},
            { // ด่าน 20: ภารกิจสูงสุด (ใกล้ 24 คำสั่ง)
                start: { r: 5, c: 0 }, targetScore: 4, map: [
                ['F','','','','','','','H'],
                ['','','','','','','',''],
                ['','','','','','','',''],
                ['','','','','H','','',''],
                ['','','','F','','','',''],
                ['','','','','','','','']
            ]}
        ];

        function initApp() {
            // สร้าง Dropdown เลือกด่าน
            const select = document.getElementById('level-select');
            for (let i = 0; i < levels.length; i++) {
                const opt = document.createElement('option');
                opt.value = i;
                opt.text = `ด่านที่ ${i + 1}`;
                select.appendChild(opt);
            }
            initSlots();
            loadLevel(0);
        }

        function loadLevel(index) {
            currentLevelIndex = parseInt(index);
            const levelData = levels[currentLevelIndex];
            
            // คัดลอกข้อมูลแผนที่
            currentMapData = JSON.parse(JSON.stringify(levelData.map));
            beePos = { ...levelData.start };
            
            document.getElementById('level-display').innerText = `ด่านที่ ${currentLevelIndex + 1}/${levels.length}`;
            document.getElementById('level-select').value = currentLevelIndex;
            document.getElementById('btn-next').style.display = 'none';
            
            commandsList = [];
            updateSlotsUI();
            drawBoard();
            showMessage(`เริ่มด่าน ${currentLevelIndex + 1}: วางแผนเพื่อเก็บไอเทมให้ครบ ${levelData.targetScore} ชิ้น`, "black");
        }

        function changeLevel(index) {
            if(!isRunning) loadLevel(index);
        }

        function resetLevel() {
            if(!isRunning) loadLevel(currentLevelIndex);
        }

        function nextLevel() {
            if (currentLevelIndex < levels.length - 1) {
                loadLevel(currentLevelIndex + 1);
            } else {
                showMessage("ยินดีด้วย! คุณผ่านครบทุกด่านแล้ว คุณคือนักเขียนโปรแกรมตัวจริง 🎉", "green");
            }
        }

        function drawBoard() {
            const board = document.getElementById('board');
            board.innerHTML = '';
            
            for (let r = 0; r < ROWS; r++) {
                for (let c = 0; c < COLS; c++) {
                    const cell = document.createElement('div');
                    cell.className = 'cell ' + getBgClass(r);
                    cell.id = `cell-${r}-${c}`;
                    
                    if (currentMapData[r][c] === 'F') cell.innerHTML = '🌻';
                    else if (currentMapData[r][c] === 'H') cell.innerHTML = '🍯';
                    
                    board.appendChild(cell);
                }
            }
            drawBee();
        }

        function getBgClass(row) {
            if(row <= 1) return 'sky';
            if(row >= 4) return 'path';
            return 'grass';
        }

        function drawBee() {
            const oldBee = document.getElementById('the-bee');
            if (oldBee) oldBee.remove();

            const cell = document.getElementById(`cell-${beePos.r}-${beePos.c}`);
            if (cell) {
                const bee = document.createElement('div');
                bee.id = 'the-bee';
                bee.className = 'bee';
                bee.innerHTML = '🐝';
                cell.appendChild(bee);
            }
        }

        function initSlots() {
            const slotsContainer = document.getElementById('slots');
            slotsContainer.innerHTML = '';
            for (let i = 1; i <= MAX_COMMANDS; i++) {
                const slot = document.createElement('div');
                slot.className = 'slot';
                slot.id = `slot-${i}`;
                
                const num = document.createElement('div');
                num.className = 'slot-number';
                num.innerText = i + '.';
                
                slot.appendChild(num);
                slotsContainer.appendChild(slot);
            }
        }

        function addCommand(cmd, icon) {
            if (isRunning) return;
            if (commandsList.length < MAX_COMMANDS) {
                commandsList.push({ action: cmd, icon: icon });
                updateSlotsUI();
            } else {
                showMessage("คำสั่งเต็ม 24 ช่องแล้ว ลองหาวิธีที่สั้นลงดูนะ!", "red");
            }
        }

        function updateSlotsUI() {
            for (let i = 1; i <= MAX_COMMANDS; i++) {
                const slot = document.getElementById(`slot-${i}`);
                while (slot.childNodes.length > 1) {
                    slot.removeChild(slot.lastChild);
                }
                if (i <= commandsList.length) {
                    const iconSpan = document.createElement('span');
                    iconSpan.innerText = commandsList[i-1].icon;
                    slot.appendChild(iconSpan);
                }
            }
        }

        function showMessage(msg, color="#d35400") {
            const msgEl = document.getElementById('message');
            msgEl.innerText = msg;
            msgEl.style.color = color;
        }

        const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

        async function runCommands() {
            if (isRunning) return;
            if (commandsList.length === 0) {
                showMessage("กรุณาใส่คำสั่งก่อนเริ่มทำงาน!");
                return;
            }

            isRunning = true;
            
            // รีเซ็ตตำแหน่งและแผนที่ให้ตรงกับด่านปัจจุบันเพื่อเริ่มวิ่ง
            beePos = { ...levels[currentLevelIndex].start };
            currentMapData = JSON.parse(JSON.stringify(levels[currentLevelIndex].map));
            drawBoard();
            
            showMessage("ผึ้งกำลังทำงาน...");
            let score = 0;
            const targetScore = levels[currentLevelIndex].targetScore;

            for (let i = 0; i < commandsList.length; i++) {
                const cmd = commandsList[i].action;
                
                document.getElementById(`slot-${i+1}`).style.backgroundColor = "#ffeaa7";

                if (cmd === 'RIGHT' && beePos.c < COLS - 1) beePos.c++;
                else if (cmd === 'LEFT' && beePos.c > 0) beePos.c--;
                else if (cmd === 'UP' && beePos.r > 0) beePos.r--;
                else if (cmd === 'DOWN' && beePos.r < ROWS - 1) beePos.r++;
                else if (cmd === 'FLOWER') {
                    if (currentMapData[beePos.r][beePos.c] === 'F') {
                        score++;
                        document.getElementById(`cell-${beePos.r}-${beePos.c}`).innerHTML = ''; 
                        currentMapData[beePos.r][beePos.c] = '';
                        showMessage(`เก็บน้ำหวานได้! (${score}/${targetScore})`, "green");
                    } else {
                        showMessage("ไม่มีน้ำหวานตรงนี้นะ!", "red");
                    }
                }
                else if (cmd === 'HONEY') {
                    if (currentMapData[beePos.r][beePos.c] === 'H') {
                        score++;
                        document.getElementById(`cell-${beePos.r}-${beePos.c}`).innerHTML = '';
                        currentMapData[beePos.r][beePos.c] = '';
                        showMessage(`เก็บน้ำผึ้งได้! (${score}/${targetScore})`, "green");
                    } else {
                        showMessage("ไม่มีรังผึ้งตรงนี้นะ!", "red");
                    }
                }

                drawBee();
                await sleep(500); 
                document.getElementById(`slot-${i+1}`).style.backgroundColor = "#fff"; 
            }

            if (score >= targetScore) {
                showMessage(`ยอดเยี่ยม! คุณผ่านด่านที่ ${currentLevelIndex + 1} แล้ว 🎉`, "green");
                document.getElementById('btn-next').style.display = 'inline-block';
            } else {
                showMessage(`ยังเก็บไอเทมไม่ครบนะ ลองจัดลำดับคำสั่งใหม่ดูอีกครั้ง!`, "red");
            }
            
            isRunning = false;
        }

        // เริ่มต้นการทำงาน
        initApp();
    </script>
</body>
</html>
